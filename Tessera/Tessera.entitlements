<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No App Sandbox: allows reading any path the user has permission for.
         The user must grant Full Disk Access in System Settings for protected paths. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
