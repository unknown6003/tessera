# Tessera landing — configuration
# Copy to `.env` to override locally. All client-exposed vars MUST be VITE_-prefixed.
#
# Tessera is free & open source — there is no checkout and no price to configure.
# Everything below has a sensible default (see src/lib/site.ts); set these only
# to override.

# Direct download URL for the macOS app build (.dmg). Defaults to the latest
# GitHub Release asset on the `tessera` repo, so any deploy (including
# git-integration) gets a working download with no config. Override to point at
# a different host.
VITE_DOWNLOAD_URL=

# Source repository (the "Star on GitHub" / source links).
VITE_GITHUB_URL=

# GitHub Sponsors page (the optional "Sponsor" button).
VITE_SPONSOR_URL=
